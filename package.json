{
  "name": "slategen",
  "version": "1.0.0",
  "description": "Video test pattern and E2 slate generator for broadcast/live production",
  "main": "main.js",
  "author": "iceyfire95",
  "scripts": {
    "start": "electron .",
    "mac:build": "electron-builder --mac --arm64 --x64",
    "mac:build:arm64": "electron-builder --mac --arm64",
    "mac:build:x64": "electron-builder --mac --x64",
    "win:build": "electron-builder --win --x64",
    "linux:build": "electron-builder --linux --x64 --arm64",
    "linux:build:x64": "electron-builder --linux --x64",
    "linux:build:arm64": "electron-builder --linux --arm64",
    "release:all": "electron-builder --mac --arm64 --x64 --win --x64 --linux --x64 --arm64"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.iceyfire95.slategen",
    "productName": "SlateGen",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "identity": null
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "AudioVideo",
      "icon": "build/icon.png",
      "maintainer": "iceyfire95",
      "synopsis": "Video test pattern and slate generator",
      "description": "SlateGen generates PNG slates and test patterns for broadcast and live production.",
      "artifactName": "${productName}_${version}_${arch}.${ext}"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libsecret-1-0"
      ]
    }
  }
}
